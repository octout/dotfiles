#!/usr/bin/env bash
#
# tmux-tree: tmux pane内で動作するファイルツリーブラウザ
# 依存: bash(4+) or zsh, find, tput, tmux
#
set -u

# --- bash 4未満の場合、zshで再実行 ---
if [[ -n "${BASH_VERSION:-}" ]] && (( ${BASH_VERSION%%.*} < 4 )); then
    exec zsh "$0" "$@"
fi

# --- シェル互換レイヤー ---
_ASSOC_KEYS=()
if [[ -n "${ZSH_VERSION:-}" ]]; then
    setopt KSH_ARRAYS NO_NOMATCH
    readc() { IFS= read -rsk"$@"; }
    assoc_keys() { eval '_ASSOC_KEYS=("${(k)'"$1"'[@]}")'; }
else
    readc() { IFS= read -rsn"$@"; }
    assoc_keys() { eval '_ASSOC_KEYS=("${!'"$1"'[@]}")'; }
fi

# --- 設定 ---
MAX_DEPTH="${TMUX_TREE_DEPTH:-4}"
ROOT_DIR="${1:-.}"
IGNORE_PATTERN="${TMUX_TREE_IGNORE:-.git}"
EDITOR_CMD="${TMUX_TREE_EDITOR:-vim}"
SPLIT_DIR="${TMUX_TREE_SPLIT:-h}"
REFRESH_INTERVAL="${TMUX_TREE_REFRESH:-5}"
PANE_WIDTH="${TMUX_TREE_WIDTH:-20%}"

# --- エスケープシーケンス (すべて $'' で事前展開) ---
CLR=$'\e[K'
NL=$'\n'
NOWRAP=$'\e[?7l'
WRAP=$'\e[?7h'
MOUSE_ON=$'\e[?1000h\e[?1006h'
MOUSE_OFF=$'\e[?1006l\e[?1000l'

C_RESET=$'\e[0m'
C_DIR=$'\e[1;34m'
C_CURSOR=$'\e[30;47m'
C_HEADER=$'\e[1;32m'
C_TREE=$'\e[90m'
C_MOD=$'\e[1;33m'
C_ADD=$'\e[1;32m'
C_DEL=$'\e[1;31m'
C_UNT=$'\e[1;31m'
C_BRANCH=$'\e[1;33m'
C_WORKTREE=$'\e[1;35m'

# --- レイアウト定数 ---
HEADER_LINES=2
FOOTER_LINES=2

# --- 状態 ---
declare -a PLAINS=()
declare -a COLORED=()
declare -a PATHS=()
declare -a TYPES=()
declare -A EXPANDED=()
CURSOR=0
SCROLL_OFFSET=0
TERM_LINES=0
TERM_COLS=0
VISIBLE=0
HR=""
DISPLAY_ROOT=""
GIT_BRANCH=""
GIT_ROOT=""
IS_GIT_REPO=false
declare -A GIT_STATUS=()
_GIT_SPLAIN=""
_GIT_SCOLORED=""
_CACHED_ROOT=""
EDITOR_PANE=""
IS_WORKTREE=false
MAIN_REPO_ROOT=""
HAS_CLAUDE_WORKTREES=false
declare -a WT_PLAINS=()
declare -a WT_COLORED=()
declare -a WT_PATHS=()
WT_SECTION_LINES=0
VIEW_MODE="tree"
SAVED_ROOT_DIR=""
SAVED_CURSOR=0
SAVED_SCROLL_OFFSET=0
declare -A SAVED_EXPANDED=()

# --- ターミナルサイズ更新 ---
update_term_size() {
    TERM_LINES=$(tput lines)
    TERM_COLS=$(tput cols)
    VISIBLE=$((TERM_LINES - HEADER_LINES - FOOTER_LINES - WT_SECTION_LINES))
    (( VISIBLE < 1 )) && VISIBLE=1
    printf -v HR '%*s' "$TERM_COLS" ''
    HR="${HR// /─}"
}

# --- git情報取得 ---
update_git_info() {
    local root="$1"

    # rootが変わったらキャッシュ無効化
    if [[ "$root" != "$_CACHED_ROOT" ]]; then
        _CACHED_ROOT="$root"
    fi

    GIT_STATUS=()
    GIT_BRANCH=""
    GIT_ROOT=""

    GIT_ROOT="$(git -C "$root" rev-parse --show-toplevel 2>/dev/null)" || {
        IS_GIT_REPO=false
        return
    }
    IS_GIT_REPO=true

    # worktree検出
    local common_dir
    common_dir="$(cd "$root" && cd "$(git rev-parse --git-common-dir 2>/dev/null)" && pwd)"
    local expected_git="${GIT_ROOT}/.git"
    if [[ "$common_dir" != "$expected_git" ]]; then
        IS_WORKTREE=true
        MAIN_REPO_ROOT="${common_dir%/.git}"
    else
        IS_WORKTREE=false
        MAIN_REPO_ROOT="$GIT_ROOT"
    fi
    [[ -d "$MAIN_REPO_ROOT/.claude/worktrees" ]] && HAS_CLAUDE_WORKTREES=true || HAS_CLAUDE_WORKTREES=false

    local line
    while IFS= read -r line; do
        if [[ "$line" == "## "* ]]; then
            # "## branch...tracking" からブランチ名を抽出
            local branch_part="${line#\#\# }"
            GIT_BRANCH="${branch_part%%...*}"
            [[ "$GIT_BRANCH" == *" "* ]] && GIT_BRANCH="${GIT_BRANCH%% *}"
            # detached HEAD の場合
            [[ "$GIT_BRANCH" == "HEAD" ]] && GIT_BRANCH="$(git -C "$root" rev-parse --short HEAD 2>/dev/null)"
            continue
        fi
        [[ -z "$line" ]] && continue
        local xy="${line:0:2}"
        local fpath="${line:3}"
        [[ "$fpath" == *" -> "* ]] && fpath="${fpath##* -> }"
        GIT_STATUS["$fpath"]="$xy"
        local dir="$fpath"
        while [[ "$dir" == */* ]]; do
            dir="${dir%/*}"
            [[ -z "${GIT_STATUS[$dir]:-}" ]] && GIT_STATUS["$dir"]="*"
        done
    done < <(git -C "$GIT_ROOT" status --porcelain -b 2>/dev/null)
}

# --- worktreeフッターセクション構築 ---
build_worktree_footer() {
    WT_PLAINS=()
    WT_COLORED=()
    WT_PATHS=()
    WT_SECTION_LINES=0

    $IS_GIT_REPO && $HAS_CLAUDE_WORKTREES || return

    local current_root
    current_root="$(cd "$ROOT_DIR" && pwd)"

    local wt_dir="$MAIN_REPO_ROOT/.claude/worktrees"

    # メインリポジトリ
    local main_branch marker
    main_branch="$(git -C "$MAIN_REPO_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null)"
    marker="  "
    [[ "$current_root" == "$MAIN_REPO_ROOT" ]] && marker="${C_HEADER}●${C_RESET} "
    WT_PLAINS+=("  main [${main_branch}]")
    WT_COLORED+=("  ${marker}${C_DIR}main${C_RESET} ${C_BRANCH}[${main_branch}]${C_RESET}")
    WT_PATHS+=("$MAIN_REPO_ROOT")

    # 各worktree
    local dir name branch
    for dir in "$wt_dir"/*/; do
        [[ -d "$dir" ]] || continue
        name="${dir%/}"
        name="${name##*/}"
        branch="$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null)" || branch="?"
        marker="  "
        [[ "$current_root" == "${dir%/}" ]] && marker="${C_HEADER}●${C_RESET} "
        WT_PLAINS+=("  ${name} [${branch}]")
        WT_COLORED+=("  ${marker}${C_WORKTREE}${name}${C_RESET} ${C_BRANCH}[${branch}]${C_RESET}")
        WT_PATHS+=("${dir%/}")
    done

    # 1 (HR) + 1 (header) + entries
    WT_SECTION_LINES=$(( 2 + ${#WT_PLAINS[@]} ))
}

# --- gitステータスラベル生成 (結果は _GIT_SPLAIN, _GIT_SCOLORED に格納) ---
git_status_label() {
    _GIT_SPLAIN=""
    _GIT_SCOLORED=""
    $IS_GIT_REPO || return
    local st="${GIT_STATUS[$1]:-}"
    [[ -z "$st" ]] && return

    case "$st" in
        "??") _GIT_SPLAIN=" ?"; _GIT_SCOLORED=" ${C_UNT}?${C_RESET}" ;;
        *M*)  _GIT_SPLAIN=" M"; _GIT_SCOLORED=" ${C_MOD}M${C_RESET}" ;;
        *A*)  _GIT_SPLAIN=" A"; _GIT_SCOLORED=" ${C_ADD}A${C_RESET}" ;;
        *D*)  _GIT_SPLAIN=" D"; _GIT_SCOLORED=" ${C_DEL}D${C_RESET}" ;;
        *R*)  _GIT_SPLAIN=" R"; _GIT_SCOLORED=" ${C_MOD}R${C_RESET}" ;;
        "*")  _GIT_SPLAIN=" *"; _GIT_SCOLORED=" ${C_MOD}*${C_RESET}" ;;
    esac
}

# --- ツリー構築 ---
build_tree() {
    PLAINS=()
    COLORED=()
    PATHS=()
    TYPES=()

    local root
    root="$(cd "$ROOT_DIR" && pwd)"

    update_git_info "$root"
    build_worktree_footer
    update_term_size

    DISPLAY_ROOT="${root/#$HOME/\~}"

    local root_slash="${root%/}/"
    local root_len=${#root_slash}

    # worktree内を閲覧中はフィルタ無効
    local filter_worktrees=false
    [[ "$root" != *"/.claude/worktrees/"* ]] && filter_worktrees=true

    # Phase 1: 中間配列に収集
    local -a _rel_arr=() _depth_arr=() _type_arr=() _name_arr=()
    local -a _gplain_arr=() _gcolor_arr=() _fpath_arr=()

    while IFS= read -r filepath; do
        [[ -z "$filepath" ]] && continue
        local rel="${filepath:$root_len}"

        if [[ -n "$IGNORE_PATTERN" && "$rel" =~ (^|/)($IGNORE_PATTERN)(/|$) ]]; then
            continue
        fi
        $filter_worktrees && [[ "$filepath" == *"/.claude/worktrees"* ]] && continue

        local stripped="${rel//[^\/]/}"
        local depth=${#stripped}

        local name="${rel##*/}"
        local git_rel=""
        $IS_GIT_REPO && git_rel="${filepath#$GIT_ROOT/}"
        git_status_label "$git_rel"

        _rel_arr+=("$rel")
        _depth_arr+=("$depth")
        _name_arr+=("$name")
        _gplain_arr+=("$_GIT_SPLAIN")
        _gcolor_arr+=("$_GIT_SCOLORED")
        _fpath_arr+=("$filepath")
        [[ -d "$filepath" ]] && _type_arr+=("d") || _type_arr+=("f")
    done < <({
        # 展開済みディレクトリのみ走査 (非展開は直下を列挙するのみ)
        find "$root" -maxdepth 1 -not -path "$root" 2>/dev/null
        assoc_keys EXPANDED
        for _d in "${_ASSOC_KEYS[@]}"; do
            [[ "${EXPANDED[$_d]}" == "1" ]] || continue
            # 祖先が全て展開されているか確認
            _a="$_d"; _v=true
            while [[ "$_a" == */* ]]; do
                _a="${_a%/*}"
                [[ "${EXPANDED[$_a]:-}" == "1" ]] || { _v=false; break; }
            done
            $_v || continue
            _s="${_d//[^\/]/}"; (( ${#_s} > MAX_DEPTH - 2 )) && continue
            _t="${root%/}/$_d"
            [[ -d "$_t" ]] || continue
            find "$_t" -maxdepth 1 -not -path "$_t" 2>/dev/null
        done
    } | while IFS= read -r _p; do
        [[ -z "$_p" ]] && continue
        # ディレクトリ優先ソート: 各パスコンポーネントにタイプ識別子を付与
        # ディレクトリ=0, ファイル=1 → 階層を保ちつつディレクトリ優先でソート
        _rel="${_p:$root_len}"
        if [[ -d "$_p" ]]; then
            printf '0%s/\t%s\n' "${_rel//\//\/0}" "$_p"
        elif [[ "$_rel" == */* ]]; then
            _par="${_rel%/*}"
            printf '0%s/1%s\t%s\n' "${_par//\//\/0}" "${_rel##*/}" "$_p"
        else
            printf '1%s\t%s\n' "$_rel" "$_p"
        fi
    done | LC_ALL=C sort -t$'\t' -k1,1 | cut -f2)

    # Phase 2: 逆方向パスで末尾兄弟判定
    local _count=${#_rel_arr[@]}
    local -a _last_sib=()
    local -a _seen_depth=()
    local idx dd

    for ((idx=_count-1; idx>=0; idx--)); do
        local d=${_depth_arr[$idx]}
        for ((dd=d+1; dd<=MAX_DEPTH; dd++)); do
            _seen_depth[$dd]=0
        done
        if (( ${_seen_depth[$d]:-0} == 0 )); then
            _last_sib[$idx]=1
            _seen_depth[$d]=1
        else
            _last_sib[$idx]=0
        fi
    done

    # Phase 3: 順方向パスで罫線付き表示文字列を構築
    local -a _is_last_at_depth=()
    for ((idx=0; idx<_count; idx++)); do
        local d=${_depth_arr[$idx]}

        # 祖先の末尾状態から動的にインデントを構築
        local ip="" ic=""
        for ((dd=0; dd<d; dd++)); do
            if (( ${_is_last_at_depth[$dd]:-0} )); then
                ip+="  "
                ic+="  "
            else
                ip+="│ "
                ic+="${C_TREE}│ ${C_RESET}"
            fi
        done

        local name="${_name_arr[$idx]}"
        local gp="${_gplain_arr[$idx]}"
        local gc="${_gcolor_arr[$idx]}"

        if [[ "${_type_arr[$idx]}" == "d" ]]; then
            local m="▸"
            [[ "${EXPANDED[${_rel_arr[$idx]}]:-}" == "1" ]] && m="▾"
            PLAINS+=("${ip}${m} ${name}/${gp}")
            COLORED+=("${ic}${C_DIR}${m} ${name}/${C_RESET}${gc}")
            TYPES+=("d")
        else
            local bc="├"
            (( _last_sib[idx] )) && bc="└"
            PLAINS+=("${ip}${bc} ${name}${gp}")
            COLORED+=("${ic}${C_TREE}${bc} ${C_RESET}${name}${gc}")
            TYPES+=("f")
        fi
        PATHS+=("${_fpath_arr[$idx]}")

        _is_last_at_depth[$d]=${_last_sib[$idx]}
    done

    local total=${#PLAINS[@]}
    if (( total == 0 )); then
        CURSOR=0
    elif (( CURSOR >= total )); then
        CURSOR=$((total - 1))
    fi
}

# --- 描画 (バッファ一括出力, サブシェルなし) ---
render() {
    # スクロール調整
    if (( CURSOR < SCROLL_OFFSET )); then
        SCROLL_OFFSET=$CURSOR
    elif (( CURSOR >= SCROLL_OFFSET + VISIBLE )); then
        SCROLL_OFFSET=$((CURSOR - VISIBLE + 1))
    fi

    local total=${#PLAINS[@]}
    local pos=$(( total > 0 ? CURSOR + 1 : 0 ))

    # バッファ構築 (サブシェルゼロ)
    local buf="${NOWRAP}"           # 自動折り返し無効
    buf+=$'\e[H'                   # カーソルをホームへ

    # ヘッダ
    if [[ "$VIEW_MODE" == "worktree" ]]; then
        buf+="${C_HEADER}  Worktrees${C_RESET} ${C_WORKTREE}[${DISPLAY_ROOT}]${C_RESET}${CLR}${NL}"
    else
        local branch_info=""
        $IS_GIT_REPO && [[ -n "$GIT_BRANCH" ]] && branch_info=" ${C_BRANCH}[${GIT_BRANCH}]${C_RESET}"
        if $IS_WORKTREE; then
            buf+="${C_WORKTREE}  [worktree]${C_RESET}${branch_info}${CLR}${NL}"
        else
            buf+="${C_HEADER}  ${DISPLAY_ROOT}${C_RESET}${branch_info}${CLR}${NL}"
        fi
    fi
    buf+="${C_TREE}${HR}${C_RESET}${CLR}${NL}"

    # ファイル一覧
    local i
    for ((i=SCROLL_OFFSET; i<SCROLL_OFFSET+VISIBLE; i++)); do
        if (( i >= 0 && i < total )); then
            if (( i == CURSOR )); then
                buf+="${C_CURSOR}${PLAINS[$i]}${CLR}${C_RESET}${NL}"
            else
                buf+="${COLORED[$i]}${CLR}${NL}"
            fi
        else
            buf+="${CLR}${NL}"
        fi
    done

    # worktreeセクション (treeビューかつworktreeがある場合)
    if [[ "$VIEW_MODE" == "tree" ]] && (( ${#WT_PLAINS[@]} > 0 )); then
        buf+="${C_TREE}${HR}${C_RESET}${CLR}${NL}"
        buf+=" ${C_TREE}worktrees${C_RESET} ${C_TREE}[w]${C_RESET}${CLR}${NL}"
        local wi
        for ((wi=0; wi<${#WT_PLAINS[@]}; wi++)); do
            buf+="${WT_COLORED[$wi]}${CLR}${NL}"
        done
    fi

    # フッタ (最終行は NL なし → スクロール防止)
    buf+="${C_TREE}${HR}${C_RESET}${CLR}${NL}"
    local help_keys
    if [[ "$VIEW_MODE" == "worktree" ]]; then
        help_keys="j/k Enter h/q [${pos}/${total}]"
    else
        help_keys="j/k Enter Space h/l r q [${pos}/${total}]"
    fi
    buf+=" ${C_TREE}${help_keys}${C_RESET}${CLR}"

    # 一括出力
    printf '%s' "$buf"
}

# --- リフレッシュ ---
refresh() {
    if [[ "$VIEW_MODE" == "worktree" ]]; then
        build_worktree_list
    else
        build_tree
    fi
    render
}

# --- worktree一覧構築 ---
build_worktree_list() {
    PLAINS=()
    COLORED=()
    PATHS=()
    TYPES=()

    local wt_dir="$MAIN_REPO_ROOT/.claude/worktrees"
    DISPLAY_ROOT="${MAIN_REPO_ROOT/#$HOME/\~}"

    # メインリポジトリ
    local main_branch
    main_branch="$(git -C "$MAIN_REPO_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null)"
    PLAINS+=("  main  [${main_branch}]")
    COLORED+=("  ${C_DIR}main${C_RESET}  ${C_BRANCH}[${main_branch}]${C_RESET}")
    PATHS+=("$MAIN_REPO_ROOT")
    TYPES+=("w")

    # 各worktree
    local dir
    for dir in "$wt_dir"/*/; do
        [[ -d "$dir" ]] || continue
        local name="${dir%/}"
        name="${name##*/}"
        local branch
        branch="$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null)" || branch="?"
        PLAINS+=("  ${name}  [${branch}]")
        COLORED+=("  ${C_WORKTREE}${name}${C_RESET}  ${C_BRANCH}[${branch}]${C_RESET}")
        PATHS+=("${dir%/}")
        TYPES+=("w")
    done

    local total=${#PLAINS[@]}
    if (( total == 0 )); then
        CURSOR=0
    elif (( CURSOR >= total )); then
        CURSOR=$((total - 1))
    fi
}

# --- worktree一覧表示トグル ---
toggle_worktree_view() {
    $IS_GIT_REPO && $HAS_CLAUDE_WORKTREES || return

    if [[ "$VIEW_MODE" == "tree" ]]; then
        SAVED_ROOT_DIR="$ROOT_DIR"
        SAVED_CURSOR=$CURSOR
        SAVED_SCROLL_OFFSET=$SCROLL_OFFSET
        SAVED_EXPANDED=()
        local k
        assoc_keys EXPANDED
        for k in "${_ASSOC_KEYS[@]}"; do
            SAVED_EXPANDED["$k"]="${EXPANDED[$k]}"
        done

        VIEW_MODE="worktree"
        CURSOR=0
        SCROLL_OFFSET=0
        build_worktree_list
        render
    else
        restore_tree_view
    fi
}

# --- ツリー表示に復帰 ---
restore_tree_view() {
    VIEW_MODE="tree"
    ROOT_DIR="$SAVED_ROOT_DIR"
    CURSOR=$SAVED_CURSOR
    SCROLL_OFFSET=$SAVED_SCROLL_OFFSET
    EXPANDED=()
    local k
    assoc_keys SAVED_EXPANDED
    for k in "${_ASSOC_KEYS[@]}"; do
        EXPANDED["$k"]="${SAVED_EXPANDED[$k]}"
    done
    refresh
}

# --- worktree選択で入る ---
enter_worktree() {
    (( ${#PLAINS[@]} == 0 )) && return
    local path="${PATHS[$CURSOR]}"
    VIEW_MODE="tree"
    change_root "$path"
}

# --- カーソル移動 ---
move_cursor() {
    local total=${#PLAINS[@]}
    (( total == 0 )) && return

    case "$1" in
        up)     (( CURSOR > 0 )) || return; ((CURSOR--)) ;;
        down)   (( CURSOR < total - 1 )) || return; ((CURSOR++)) ;;
        top)    (( CURSOR == 0 )) && return; CURSOR=0 ;;
        bottom) (( CURSOR == total - 1 )) && return; CURSOR=$((total - 1)) ;;
    esac

    render
}

# --- ファイルを開く ---
open_file() {
    (( ${#PLAINS[@]} == 0 )) && return
    [[ "${TYPES[$CURSOR]}" == "w" ]] && { enter_worktree; return; }
    local path="${PATHS[$CURSOR]}"

    if [[ -d "$path" ]]; then
        toggle_collapse
        return
    fi

    if [[ -n "${TMUX:-}" ]]; then
        if [[ -n "$EDITOR_PANE" ]] && tmux list-panes -F '#{pane_id}' | grep -qF "$EDITOR_PANE"; then
            tmux send-keys -t "$EDITOR_PANE" Escape
            tmux send-keys -t "$EDITOR_PANE" -l ":edit ${path// /\\ }"
            tmux send-keys -t "$EDITOR_PANE" Enter
        else
            local tree_pane
            tree_pane=$(tmux display-message -p '#{pane_id}')
            EDITOR_PANE=$(tmux split-window -fh -P -F '#{pane_id}' "$EDITOR_CMD" "$path")
            tmux resize-pane -t "$tree_pane" -x "$PANE_WIDTH"
        fi
        tmux select-pane -t "$EDITOR_PANE"
    else
        "$EDITOR_CMD" "$path"
    fi
}

# --- 展開トグル ---
toggle_collapse() {
    (( ${#PLAINS[@]} == 0 )) && return
    local path="${PATHS[$CURSOR]}"
    [[ ! -d "$path" ]] && return

    local root_slash
    root_slash="$(cd "$ROOT_DIR" && pwd)/"
    local rel="${path#$root_slash}"

    if [[ "${EXPANDED[$rel]:-}" == "1" ]]; then
        unset 'EXPANDED[$rel]'
    else
        EXPANDED["$rel"]="1"
    fi
    refresh
}

# --- ルートディレクトリ変更 ---
change_root() {
    ROOT_DIR="$1"
    CURSOR=0
    SCROLL_OFFSET=0
    EXPANDED=()
    refresh
}

# --- ディレクトリに入る ---
enter_dir() {
    (( ${#PLAINS[@]} == 0 )) && return
    local path="${PATHS[$CURSOR]}"
    [[ -d "$path" ]] && change_root "$path"
}

# --- 親ディレクトリへ ---
go_parent() {
    if [[ "$VIEW_MODE" == "worktree" ]]; then
        restore_tree_view
        return
    fi
    local current
    current="$(cd "$ROOT_DIR" && pwd)"
    # worktree内からはメインリポジトリのルートに直接戻る
    if [[ "$current" == *"/.claude/worktrees/"* && -n "$MAIN_REPO_ROOT" ]]; then
        change_root "$MAIN_REPO_ROOT"
        return
    fi
    local parent="${current%/*}"
    [[ -z "$parent" ]] && parent="/"
    [[ "$parent" != "$current" ]] && change_root "$parent"
}

# --- ディレクトリなら入る、ファイルなら開く ---
enter_or_open() {
    (( ${#PLAINS[@]} == 0 )) && return
    case "${TYPES[$CURSOR]}" in
        w) enter_worktree ;;
        d) enter_dir ;;
        *) open_file ;;
    esac
}

# --- マウスイベント処理 ---
handle_mouse() {
    local button="$1" row="$2"
    case "$button" in
        0)  # 1-basedの行番号からヘッダ分を引いてエントリインデックスを算出
            local idx=$((SCROLL_OFFSET + row - HEADER_LINES - 1))
            local total=${#PLAINS[@]}
            if (( idx >= 0 && idx < total )); then
                CURSOR=$idx
                render
                open_file
            fi
            ;;
        64) move_cursor up ;;
        65) move_cursor down ;;
    esac
}

# --- キー入力 ---
handle_input() {
    local key
    if ! readc 1 -t "$REFRESH_INTERVAL" key; then
        refresh
        return
    fi

    case "$key" in
        j) move_cursor down ;;
        k) move_cursor up ;;
        g) move_cursor top ;;
        G) move_cursor bottom ;;
        "") open_file ;;
        " ") toggle_collapse ;;
        l) enter_or_open ;;
        h) go_parent ;;
        r) refresh ;;
        w) toggle_worktree_view ;;
        q) if [[ "$VIEW_MODE" == "worktree" ]]; then restore_tree_view; else exit 0; fi ;;
        $'\e')
            local seq
            readc 2 -t 0.05 seq
            case "$seq" in
                '[A') move_cursor up ;;
                '[B') move_cursor down ;;
                '[C') enter_or_open ;;
                '[D') go_parent ;;
                '[<')
                    # SGRマウス: ESC[<ボタン;列;行M(press)/m(release)
                    local mouse_data="" ch=""
                    while readc 1 -t 0.05 ch; do
                        [[ "$ch" == "M" || "$ch" == "m" ]] && break
                        mouse_data+="$ch"
                        (( ${#mouse_data} > 20 )) && break
                    done
                    if [[ "$ch" == "M" ]]; then
                        local mb mx my
                        IFS=';' read -r mb mx my <<< "$mouse_data"
                        handle_mouse "$mb" "$my"
                    fi
                    ;;
            esac ;;
    esac
}

# --- クリーンアップ ---
cleanup() {
    printf '%s' "$MOUSE_OFF"
    printf '%s' "${WRAP}"  # 自動折り返し復帰
    tput cnorm
    tput rmcup
    stty echo 2>/dev/null
}

# --- メイン ---
main() {
    # tmux内で起動した場合、ペインを指定幅にリサイズ
    [[ -n "${TMUX:-}" ]] && tmux resize-pane -x "$PANE_WIDTH"

    tput smcup
    tput civis
    stty -echo 2>/dev/null
    printf '%s' "$MOUSE_ON"
    trap cleanup EXIT
    trap 'update_term_size; render' WINCH

    update_term_size
    build_tree
    render

    while true; do
        handle_input
    done
}

main
