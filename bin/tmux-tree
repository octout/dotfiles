#!/usr/bin/env bash
#
# tmux-tree: tmux pane内で動作するファイルツリーブラウザ
# 依存: bash(4+), find, tput, tmux
#
set -u

# --- 設定 ---
MAX_DEPTH="${TMUX_TREE_DEPTH:-4}"
ROOT_DIR="${1:-.}"
IGNORE_PATTERN="${TMUX_TREE_IGNORE:-.git|node_modules|__pycache__|.venv|.cache}"
EDITOR_CMD="${TMUX_TREE_EDITOR:-vim}"
SPLIT_DIR="${TMUX_TREE_SPLIT:-h}"
REFRESH_INTERVAL="${TMUX_TREE_REFRESH:-5}"
PANE_WIDTH="${TMUX_TREE_WIDTH:-20%}"

# --- エスケープシーケンス (すべて $'' で事前展開) ---
CLR=$'\e[K'
NL=$'\n'
NOWRAP=$'\e[?7l'
WRAP=$'\e[?7h'

C_RESET=$'\e[0m'
C_DIR=$'\e[1;34m'
C_CURSOR=$'\e[30;47m'
C_HEADER=$'\e[1;32m'
C_TREE=$'\e[90m'
C_MOD=$'\e[1;33m'
C_ADD=$'\e[1;32m'
C_DEL=$'\e[1;31m'
C_UNT=$'\e[1;31m'
C_BRANCH=$'\e[1;33m'
C_WORKTREE=$'\e[1;35m'

# --- 状態 ---
declare -a PLAINS=()
declare -a COLORED=()
declare -a PATHS=()
declare -a TYPES=()
declare -A EXPANDED=()
CURSOR=0
SCROLL_OFFSET=0
TERM_LINES=0
TERM_COLS=0
VISIBLE=0
HR=""
DISPLAY_ROOT=""
GIT_BRANCH=""
GIT_ROOT=""
IS_GIT_REPO=false
declare -A GIT_STATUS=()
_GIT_SPLAIN=""
_GIT_SCOLORED=""
EDITOR_PANE=""
IS_WORKTREE=false
MAIN_REPO_ROOT=""
HAS_CLAUDE_WORKTREES=false
VIEW_MODE="tree"
SAVED_ROOT_DIR=""
SAVED_CURSOR=0
SAVED_SCROLL_OFFSET=0
declare -A SAVED_EXPANDED=()

# --- ターミナルサイズ更新 ---
update_term_size() {
    TERM_LINES="${LINES:-$(tput lines)}"
    TERM_COLS="${COLUMNS:-$(tput cols)}"
    VISIBLE=$((TERM_LINES - 4))
    (( VISIBLE < 1 )) && VISIBLE=1
    printf -v HR '%*s' "$TERM_COLS" ''
    HR="${HR// /─}"
}

# --- git情報取得 ---
update_git_info() {
    GIT_STATUS=()
    GIT_BRANCH=""
    GIT_ROOT=""

    local root="$1"

    GIT_ROOT="$(git -C "$root" rev-parse --show-toplevel 2>/dev/null)" || {
        IS_GIT_REPO=false
        return
    }
    IS_GIT_REPO=true

    # worktree検出
    local common_dir
    common_dir="$(cd "$root" && cd "$(git rev-parse --git-common-dir 2>/dev/null)" && pwd)"
    local expected_git="${GIT_ROOT}/.git"
    if [[ "$common_dir" != "$expected_git" ]]; then
        IS_WORKTREE=true
        MAIN_REPO_ROOT="${common_dir%/.git}"
    else
        IS_WORKTREE=false
        MAIN_REPO_ROOT="$GIT_ROOT"
    fi
    [[ -d "$MAIN_REPO_ROOT/.claude/worktrees" ]] && HAS_CLAUDE_WORKTREES=true || HAS_CLAUDE_WORKTREES=false

    local line
    while IFS= read -r line; do
        if [[ "$line" == "## "* ]]; then
            # "## branch...tracking" からブランチ名を抽出
            local branch_part="${line#\#\# }"
            GIT_BRANCH="${branch_part%%...*}"
            [[ "$GIT_BRANCH" == *" "* ]] && GIT_BRANCH="${GIT_BRANCH%% *}"
            # detached HEAD の場合
            [[ "$GIT_BRANCH" == "HEAD" ]] && GIT_BRANCH="$(git -C "$root" rev-parse --short HEAD 2>/dev/null)"
            continue
        fi
        [[ -z "$line" ]] && continue
        local xy="${line:0:2}"
        local fpath="${line:3}"
        [[ "$fpath" == *" -> "* ]] && fpath="${fpath##* -> }"
        GIT_STATUS["$fpath"]="$xy"
        local dir="$fpath"
        while [[ "$dir" == */* ]]; do
            dir="${dir%/*}"
            [[ -z "${GIT_STATUS[$dir]:-}" ]] && GIT_STATUS["$dir"]="*"
        done
    done < <(git -C "$GIT_ROOT" status --porcelain -b 2>/dev/null)
}

# --- gitステータスラベル生成 (結果は _GIT_SPLAIN, _GIT_SCOLORED に格納) ---
git_status_label() {
    _GIT_SPLAIN=""
    _GIT_SCOLORED=""
    $IS_GIT_REPO || return
    local st="${GIT_STATUS[$1]:-}"
    [[ -z "$st" ]] && return

    case "$st" in
        "??") _GIT_SPLAIN=" ?"; _GIT_SCOLORED=" ${C_UNT}?${C_RESET}" ;;
        *M*)  _GIT_SPLAIN=" M"; _GIT_SCOLORED=" ${C_MOD}M${C_RESET}" ;;
        *A*)  _GIT_SPLAIN=" A"; _GIT_SCOLORED=" ${C_ADD}A${C_RESET}" ;;
        *D*)  _GIT_SPLAIN=" D"; _GIT_SCOLORED=" ${C_DEL}D${C_RESET}" ;;
        *R*)  _GIT_SPLAIN=" R"; _GIT_SCOLORED=" ${C_MOD}R${C_RESET}" ;;
        "*")  _GIT_SPLAIN=" *"; _GIT_SCOLORED=" ${C_MOD}*${C_RESET}" ;;
    esac
}

# --- ツリー構築 ---
build_tree() {
    PLAINS=()
    COLORED=()
    PATHS=()
    TYPES=()

    local root
    root="$(cd "$ROOT_DIR" && pwd)"

    update_git_info "$root"

    DISPLAY_ROOT="${root/#$HOME/\~}"

    local root_slash="${root%/}/"
    local root_len=${#root_slash}

    # worktree内を閲覧中はフィルタ無効
    local filter_worktrees=false
    [[ "$root" != *"/.claude/worktrees/"* ]] && filter_worktrees=true

    # インデント文字列を事前計算
    local -a indent_plain=("") indent_colored=("")
    local d
    for ((d=1; d<=MAX_DEPTH; d++)); do
        indent_plain[d]="${indent_plain[d-1]}│ "
        indent_colored[d]="${indent_colored[d-1]}${C_TREE}│ ${C_RESET}"
    done

    while IFS= read -r filepath; do
        local rel="${filepath:$root_len}"

        if [[ -n "$IGNORE_PATTERN" && "$rel" =~ (^|/)($IGNORE_PATTERN)(/|$) ]]; then
            continue
        fi
        # .claude/worktrees はツリーに表示しない
        $filter_worktrees && [[ "$filepath" == *"/.claude/worktrees"* ]] && continue

        local stripped="${rel//[^\/]/}"
        local depth=${#stripped}

        if (( depth > 0 )); then
            local parent_rel="${rel%/*}"
            local check="$parent_rel"
            local vis=1
            while [[ -n "$check" ]]; do
                if [[ "${EXPANDED[$check]:-}" != "1" ]]; then
                    vis=0
                    break
                fi
                [[ "$check" == */* ]] && check="${check%/*}" || break
            done
            (( vis == 0 )) && continue
        fi

        local ip="${indent_plain[$depth]}"
        local ic="${indent_colored[$depth]}"
        local name="${rel##*/}"

        local git_rel=""
        $IS_GIT_REPO && git_rel="${filepath#$GIT_ROOT/}"
        git_status_label "$git_rel"

        if [[ -d "$filepath" ]]; then
            local m="▸"
            [[ "${EXPANDED[$rel]:-}" == "1" ]] && m="▾"
            PLAINS+=("${ip}${m} ${name}/${_GIT_SPLAIN}")
            COLORED+=("${ic}${C_DIR}${m} ${name}/${C_RESET}${_GIT_SCOLORED}")
            TYPES+=("d")
        else
            PLAINS+=("${ip}├ ${name}${_GIT_SPLAIN}")
            COLORED+=("${ic}${C_TREE}├ ${C_RESET}${name}${_GIT_SCOLORED}")
            TYPES+=("f")
        fi
        PATHS+=("$filepath")
    done < <(find "$root" -maxdepth "$MAX_DEPTH" -not -path "$root" 2>/dev/null | LC_ALL=C sort)

    local total=${#PLAINS[@]}
    if (( total == 0 )); then
        CURSOR=0
    elif (( CURSOR >= total )); then
        CURSOR=$((total - 1))
    fi
}

# --- 描画 (バッファ一括出力, サブシェルなし) ---
render() {
    # スクロール調整
    if (( CURSOR < SCROLL_OFFSET )); then
        SCROLL_OFFSET=$CURSOR
    elif (( CURSOR >= SCROLL_OFFSET + VISIBLE )); then
        SCROLL_OFFSET=$((CURSOR - VISIBLE + 1))
    fi

    local total=${#PLAINS[@]}
    local pos=$(( total > 0 ? CURSOR + 1 : 0 ))

    # バッファ構築 (サブシェルゼロ)
    local buf="${NOWRAP}"           # 自動折り返し無効
    buf+=$'\e[H'                   # カーソルをホームへ

    # ヘッダ
    if [[ "$VIEW_MODE" == "worktree" ]]; then
        buf+="${C_HEADER}  Worktrees${C_RESET} ${C_WORKTREE}[${DISPLAY_ROOT}]${C_RESET}${CLR}${NL}"
    else
        local branch_info=""
        $IS_GIT_REPO && [[ -n "$GIT_BRANCH" ]] && branch_info=" ${C_BRANCH}[${GIT_BRANCH}]${C_RESET}"
        if $IS_WORKTREE; then
            buf+="${C_WORKTREE}  [worktree]${C_RESET}${branch_info}${CLR}${NL}"
        else
            buf+="${C_HEADER}  ${DISPLAY_ROOT}${C_RESET}${branch_info}${CLR}${NL}"
        fi
    fi
    buf+="${C_TREE}${HR}${C_RESET}${CLR}${NL}"

    # ファイル一覧
    local i
    for ((i=SCROLL_OFFSET; i<SCROLL_OFFSET+VISIBLE; i++)); do
        if (( i >= 0 && i < total )); then
            if (( i == CURSOR )); then
                buf+="${C_CURSOR}${PLAINS[$i]}${CLR}${C_RESET}${NL}"
            else
                buf+="${COLORED[$i]}${CLR}${NL}"
            fi
        else
            buf+="${CLR}${NL}"
        fi
    done

    # フッタ (最終行は NL なし → スクロール防止)
    buf+="${C_TREE}${HR}${C_RESET}${CLR}${NL}"
    local help_keys
    if [[ "$VIEW_MODE" == "worktree" ]]; then
        help_keys="j/k Enter h/q [${pos}/${total}]"
    elif $HAS_CLAUDE_WORKTREES; then
        help_keys="j/k Enter Space h/l r q w [${pos}/${total}]"
    else
        help_keys="j/k Enter Space h/l r q [${pos}/${total}]"
    fi
    buf+=" ${C_TREE}${help_keys}${C_RESET}${CLR}"

    # 一括出力
    printf '%s' "$buf"
}

# --- リフレッシュ ---
refresh() {
    if [[ "$VIEW_MODE" == "worktree" ]]; then
        build_worktree_list
    else
        build_tree
    fi
    render
}

# --- worktree一覧構築 ---
build_worktree_list() {
    PLAINS=()
    COLORED=()
    PATHS=()
    TYPES=()

    local wt_dir="$MAIN_REPO_ROOT/.claude/worktrees"
    DISPLAY_ROOT="${MAIN_REPO_ROOT/#$HOME/\~}"

    # メインリポジトリ
    local main_branch
    main_branch="$(git -C "$MAIN_REPO_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null)"
    PLAINS+=("  main  [${main_branch}]")
    COLORED+=("  ${C_DIR}main${C_RESET}  ${C_BRANCH}[${main_branch}]${C_RESET}")
    PATHS+=("$MAIN_REPO_ROOT")
    TYPES+=("w")

    # 各worktree
    local dir
    for dir in "$wt_dir"/*/; do
        [[ -d "$dir" ]] || continue
        local name="${dir%/}"
        name="${name##*/}"
        local branch
        branch="$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null)" || branch="?"
        PLAINS+=("  ${name}  [${branch}]")
        COLORED+=("  ${C_WORKTREE}${name}${C_RESET}  ${C_BRANCH}[${branch}]${C_RESET}")
        PATHS+=("${dir%/}")
        TYPES+=("w")
    done

    local total=${#PLAINS[@]}
    if (( total == 0 )); then
        CURSOR=0
    elif (( CURSOR >= total )); then
        CURSOR=$((total - 1))
    fi
}

# --- worktree一覧表示トグル ---
toggle_worktree_view() {
    $IS_GIT_REPO && $HAS_CLAUDE_WORKTREES || return

    if [[ "$VIEW_MODE" == "tree" ]]; then
        SAVED_ROOT_DIR="$ROOT_DIR"
        SAVED_CURSOR=$CURSOR
        SAVED_SCROLL_OFFSET=$SCROLL_OFFSET
        SAVED_EXPANDED=()
        local k
        for k in "${!EXPANDED[@]}"; do
            SAVED_EXPANDED["$k"]="${EXPANDED[$k]}"
        done

        VIEW_MODE="worktree"
        CURSOR=0
        SCROLL_OFFSET=0
        build_worktree_list
        render
    else
        restore_tree_view
    fi
}

# --- ツリー表示に復帰 ---
restore_tree_view() {
    VIEW_MODE="tree"
    ROOT_DIR="$SAVED_ROOT_DIR"
    CURSOR=$SAVED_CURSOR
    SCROLL_OFFSET=$SAVED_SCROLL_OFFSET
    EXPANDED=()
    local k
    for k in "${!SAVED_EXPANDED[@]}"; do
        EXPANDED["$k"]="${SAVED_EXPANDED[$k]}"
    done
    refresh
}

# --- worktree選択で入る ---
enter_worktree() {
    (( ${#PLAINS[@]} == 0 )) && return
    local path="${PATHS[$CURSOR]}"
    VIEW_MODE="tree"
    change_root "$path"
}

# --- カーソル移動 ---
move_cursor() {
    local total=${#PLAINS[@]}
    (( total == 0 )) && return

    case "$1" in
        up)     (( CURSOR > 0 )) || return; ((CURSOR--)) ;;
        down)   (( CURSOR < total - 1 )) || return; ((CURSOR++)) ;;
        top)    (( CURSOR == 0 )) && return; CURSOR=0 ;;
        bottom) (( CURSOR == total - 1 )) && return; CURSOR=$((total - 1)) ;;
    esac

    render
}

# --- ファイルを開く ---
open_file() {
    (( ${#PLAINS[@]} == 0 )) && return
    [[ "${TYPES[$CURSOR]}" == "w" ]] && { enter_worktree; return; }
    local path="${PATHS[$CURSOR]}"

    if [[ -d "$path" ]]; then
        toggle_collapse
        return
    fi

    if [[ -n "${TMUX:-}" ]]; then
        if [[ -n "$EDITOR_PANE" ]] && tmux list-panes -F '#{pane_id}' | grep -qF "$EDITOR_PANE"; then
            tmux send-keys -t "$EDITOR_PANE" Escape
            tmux send-keys -t "$EDITOR_PANE" -l ":edit ${path// /\\ }"
            tmux send-keys -t "$EDITOR_PANE" Enter
        else
            EDITOR_PANE=$(tmux split-window -"$SPLIT_DIR" -P -F '#{pane_id}' "$EDITOR_CMD" "$path")
        fi
        tmux select-pane -t "$EDITOR_PANE"
    else
        "$EDITOR_CMD" "$path"
    fi
}

# --- 展開トグル ---
toggle_collapse() {
    (( ${#PLAINS[@]} == 0 )) && return
    local path="${PATHS[$CURSOR]}"
    [[ ! -d "$path" ]] && return

    local root_slash
    root_slash="$(cd "$ROOT_DIR" && pwd)/"
    local rel="${path#$root_slash}"

    if [[ "${EXPANDED[$rel]:-}" == "1" ]]; then
        unset 'EXPANDED[$rel]'
    else
        EXPANDED["$rel"]="1"
    fi
    refresh
}

# --- ルートディレクトリ変更 ---
change_root() {
    ROOT_DIR="$1"
    CURSOR=0
    SCROLL_OFFSET=0
    EXPANDED=()
    refresh
}

# --- ディレクトリに入る ---
enter_dir() {
    (( ${#PLAINS[@]} == 0 )) && return
    local path="${PATHS[$CURSOR]}"
    [[ -d "$path" ]] && change_root "$path"
}

# --- 親ディレクトリへ ---
go_parent() {
    if [[ "$VIEW_MODE" == "worktree" ]]; then
        restore_tree_view
        return
    fi
    local current
    current="$(cd "$ROOT_DIR" && pwd)"
    local parent="${current%/*}"
    [[ -z "$parent" ]] && parent="/"
    [[ "$parent" != "$current" ]] && change_root "$parent"
}

# --- ディレクトリなら入る、ファイルなら開く ---
enter_or_open() {
    (( ${#PLAINS[@]} == 0 )) && return
    case "${TYPES[$CURSOR]}" in
        w) enter_worktree ;;
        d) enter_dir ;;
        *) open_file ;;
    esac
}

# --- キー入力 ---
handle_input() {
    local key
    if ! IFS= read -rsn1 -t "$REFRESH_INTERVAL" key; then
        refresh
        return
    fi

    case "$key" in
        j) move_cursor down ;;
        k) move_cursor up ;;
        g) move_cursor top ;;
        G) move_cursor bottom ;;
        "") open_file ;;
        " ") toggle_collapse ;;
        l) enter_or_open ;;
        h) go_parent ;;
        r) refresh ;;
        w) toggle_worktree_view ;;
        q) if [[ "$VIEW_MODE" == "worktree" ]]; then restore_tree_view; else exit 0; fi ;;
        $'\e')
            local seq
            IFS= read -rsn2 -t 0.05 seq
            case "$seq" in
                '[A') move_cursor up ;;
                '[B') move_cursor down ;;
                '[C') enter_or_open ;;
                '[D') go_parent ;;
            esac ;;
    esac
}

# --- クリーンアップ ---
cleanup() {
    printf '%s' "${WRAP}"  # 自動折り返し復帰
    tput cnorm
    tput rmcup
    stty echo 2>/dev/null
}

# --- メイン ---
main() {
    # tmux内で起動した場合、ペインを指定幅にリサイズ
    [[ -n "${TMUX:-}" ]] && tmux resize-pane -x "$PANE_WIDTH"

    tput smcup
    tput civis
    trap cleanup EXIT
    trap 'update_term_size; render' WINCH

    update_term_size
    build_tree
    render

    while true; do
        handle_input
    done
}

main
